# Canonical site URL (no www).
# Fuente ÚNICA de verdad para el SEO: metadataBase, canonical, Open Graph,
# hreflang y sitemap.xml se derivan de esta variable. También la usa la app.
# En producción debe apuntar al dominio canónico. Sin ella, el código cae por
# defecto a https://giivngo.com.
NEXT_PUBLIC_APP_URL=https://giivngo.com

# Landing Page Selection
# Set to 'home1' for Lifestyle Hero Focus design
# Set to 'home2' for Social Gifting Platform design
NEXT_PUBLIC_ACTIVE_HOME=home1
